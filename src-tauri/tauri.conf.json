{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WallpaperEngineLinux",
  "version": "0.1.0",
  "identifier": "online.opencom.wallpaper-engine-linux",
  "build": {
    "frontendDist": "src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Wallpaper Engine",
        "width": 1320,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
